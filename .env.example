# ─────────────────────────────────────────────────────────────
# Loop — environment configuration
# Copy this file to `.env` and fill in the blanks. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# ── Slack (Socket Mode — no public URL needed, easiest for dev) ──
# Tokens come from your Slack app(s) at https://api.slack.com/apps. Per app:
#   • Bot token (xoxb-…): "OAuth & Permissions" → Bot User OAuth Token. Add scopes
#       app_mentions:read, chat:write, commands, reactions:write, files:read,
#       channels:history, groups:history, im:history, users:read
#     then Install / Reinstall the app.
#   • App-level token (xapp-…): "Basic Information" → App-Level Tokens → Generate,
#       scope  connections:write.
#   • Enable "Socket Mode", and under "Event Subscriptions" SUBSCRIBE TO BOT EVENTS
#       app_mention + message.im   ← without this the socket connects but NO events
#       arrive (the #1 "my bot is silent" cause). Optionally add the /loop command.
#
# Loop runs ONE app or SEVERAL at once (they coexist, each can have its own
# persona). Pick a style:
#
# ▸ Single app (back-compat): one bare pair.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_APP_NAME=loop                  # optional label (default "loop")
#
# ▸ Multiple apps: a SLACK_BOT_TOKEN_<NAME> + SLACK_APP_TOKEN_<NAME> pair per app.
SLACK_BOT_TOKEN_LOOP=xoxb-...          # the "Loop" app (app id A0BC0NPB9LN)
SLACK_APP_TOKEN_LOOP=xapp-...
SLACK_BOT_TOKEN_RASPUTIN=xoxb-...      # the "Rasputin_Loop" app (app id A0BCVHES936)
SLACK_APP_TOKEN_RASPUTIN=xapp-...
#
# Optional — give each app different behavior (appended to that app's system
# prompt; the <NAME> matches the token suffix, uppercased):
# LOOP_PERSONA_LOOP=You are the team's general assistant.
# LOOP_PERSONA_RASPUTIN=You are the on-call incident assistant; be terse and precise.

# ── Model provider ────────────────────────────────────────────
# Loop's USP: the provider is ENV-SELECTED, not hardcoded — no vendor lock-in.
# LOOP_MODEL_PROVIDER picks the backend; the agent code never changes.
#   anthropic (default) — Anthropic SDK; also serves any Anthropic-COMPATIBLE
#                         endpoint (MiniMax M3, native Claude, proxies) via
#                         ANTHROPIC_BASE_URL. Needs no extra install.
#   bedrock             — AWS Bedrock (region-resident; works out of the box,
#                         boto3 ships with strands). Set LOOP_BEDROCK_REGION.
#   litellm             — LiteLLM multi-provider gateway (one config, many
#                         providers; model id like "openai/gpt-4o").
#   openai              — OpenAI or any OpenAI-compatible endpoint (OPENAI_BASE_URL).
#   ollama              — local / self-hosted models (LOOP_OLLAMA_HOST), fully sovereign.
#   gemini              — Google Gemini.
# For everything except anthropic/bedrock:  pip install -e ".[providers]"
#
# LOOP_MODEL_PROVIDER=anthropic        # default
# LOOP_MODEL=                          # provider-neutral model id (falls back to ANTHROPIC_MODEL)
# LOOP_MAX_TOKENS=2048                 # response cap (was hardcoded; now tunable)
# LOOP_AMBIENT_MODEL=                  # optional cheaper model for background ambient runs (see Ambient below)
#
# Non-anthropic provider knobs (only read when that provider is selected):
# OPENAI_API_KEY= / OPENAI_BASE_URL=   (openai; LiteLLM also reads provider keys from env)
# LOOP_BEDROCK_REGION=us-east-1        (bedrock; falls back to AWS_REGION + standard AWS creds)
# LOOP_OLLAMA_HOST=http://localhost:11434   (ollama)
# GEMINI_API_KEY= / GOOGLE_API_KEY=    (gemini)
#
# ▸ Option A — MiniMax M3 (default for this project)
#   Get a key: https://www.minimax.io/platform/user-center/basic-information
#     → left sidebar "API Keys" → "Create new secret key" → copy it ONCE
#       (MiniMax shows the secret only once; losing it means regenerating).
#     Your Group ID lives on the same "Basic Information" page if a tool needs it.
ANTHROPIC_API_KEY=                                # paste your MiniMax API key
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
ANTHROPIC_MODEL=MiniMax-M3
#   Other valid ids: MiniMax-M2.7 / MiniMax-M2.7-highspeed,
#                    MiniMax-M2.5 / MiniMax-M2.5-highspeed, MiniMax-M2
#
# ▸ Option B — native Anthropic (clear the three MiniMax lines above, use these)
#   ANTHROPIC_API_KEY=sk-ant-...
#   ANTHROPIC_BASE_URL=https://api.anthropic.com
#   ANTHROPIC_MODEL=claude-sonnet-4-6
#
# ANTHROPIC_AUTH_TOKEN — alternate to ANTHROPIC_API_KEY, used ONLY when the API
# key is unset (handy for some proxies). Leave blank for the MiniMax setup above.
# ANTHROPIC_AUTH_TOKEN=

# ── Storage (local SQLite; the file + parent dir are created on first run) ──
# Long-term memory is episodic + provenance-stamped (who/where/when is attached
# automatically) and recalled via FTS5 full-text search (BM25 + recency). This is
# all stdlib SQLite — no extra deps, no API key, nothing to configure here.
DATABASE_PATH=./data/loop.db

# ── Memory backend: hybrid (lexical + semantic) RAG over libSQL/Turso ──
# Default "sqlite" = FTS5 + provenance store (no deps, no key). "hybrid" adds
# semantic vector recall fused with FTS5 (RRF) for proper Agentic RAG.
#   pip install -e ".[vector]"   # libsql-experimental + fastembed
# LOOP_MEMORY_BACKEND=hybrid          # default "sqlite"; aliases libsql/turso/vector
# LOOP_EMBEDDINGS=fastembed           # fastembed (local, NO key) | minimax | openai | hashing
# LOOP_VECTOR_DB_PATH=./data/loop_vec.db
# minimax embeddings (embo-01) need ONLY the key — no Group ID on api.minimax.io.
# Optional Turso cloud sync: TURSO_DATABASE_URL=libsql://<db>.turso.io  TURSO_AUTH_TOKEN=...
# See docs/vector-memory.md.

# ── Memory scope: per-channel isolation (Claude-Tag-style) ──
# Controls what recall can SEE. A fact saved in #support is not recalled in
# #data-team under "channel". Provenance (channel/team) is already stamped on
# every memory, so this is a recall-time filter — no migration.
#   channel (default) — isolate memory to the originating channel.
#   team              — isolate to the workspace/team.
#   global            — no filter (legacy behavior; memory shared everywhere).
# LOOP_MEMORY_SCOPE=channel
# Per-app override (run one identity isolated, another shared) — <NAME> = app name:
# LOOP_MEMORY_SCOPE_RASPUTIN=channel
# LOOP_MEMORY_SCOPE_LOOP=global

# ── Slack AI capabilities: native "Assistant" pane ──
# Off by default. When on, Loop also serves the Slack AI assistant side-panel /
# app DM with suggested prompts + a live "is thinking…" status, routed to the
# same agent. REQUIRES, per Slack app: the "Agents & AI Apps" feature enabled,
# the `assistant:write` scope, and the assistant_thread_started /
# assistant_thread_context_changed events subscribed. See docs/slack-assistant.md.
# LOOP_SLACK_ASSISTANT=on

# ── Ambient mode: proactive PM that follows up on stalled threads ──
# Off by default. When on, each app runs a background daemon that finds threads
# which have gone quiet without resolution and posts a concise follow-up. The
# default discovery is NARROW — only threads this app already participated in
# (queried from the `interactions` table); no new Slack scopes, no channel-wide
# surveillance. It re-checks real staleness via conversations_replies before
# nudging, and never nudges the same thread twice within the re-nudge window.
# Needs the bot in the channel + scopes: channels:history (+ groups:history for
# private channels), chat:write.
# LOOP_AMBIENT=on
# LOOP_AMBIENT_INTERVAL_SEC=900       # how often each app scans (default 15 min)
# LOOP_AMBIENT_STALE_HOURS=24         # a thread is "stale" after this much silence
# LOOP_AMBIENT_RENUDGE_HOURS=48       # don't nudge the same thread again within this
# LOOP_AMBIENT_MAX_THREADS=3          # max threads nudged per scan (cost guard)
# LOOP_AMBIENT_CHANNELS=C0123,C0456   # optional allow-list (default: all touched channels)
# LOOP_AMBIENT_MODEL=                 # optional cheaper/local model for background scans
#                                     # (cost routing — see Model provider above)

# ── Optional: load MCP tool servers at runtime (a stdio command + args) ──
# Also the seam for the autonomous SANDBOX / code-exec capability: point this at a
# containerized code-interpreter MCP server and the agent can resolve delegated
# coding tasks in an isolated sandbox, then post results back in-thread. The
# sandbox's own isolation is the safety boundary (the guardrail risky-method
# blocklist only covers the `slack` tool). NOTE: one stdio server at a time today.
# LOOP_MCP_SERVERS=uvx strands-agents-mcp-server

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
# Set LOG_LEVEL=DEBUG to also log full model reasoning ("thinking") and the raw
# inputs/outputs of every tool call.

# ── Observability (Pillar 02) ─────────────────────────────────
# Per-interaction telemetry (request id, tokens, tool calls, latency, outcome)
# and per-step traces (each model API call, tool call, reasoning) are always
# persisted to the SQLite `interactions` / `steps` tables. LOOP_TRACE only
# controls whether step traces are also printed to the logs.
LOOP_TRACE=on

# ── Guardrails (Pillars 04/05) — enforce by default, per-rule toggles ──
# A rule is OFF when its value is 0 (or empty for the blocklist).
LOOP_GUARDRAILS=on                 # master switch (on/off)
LOOP_MAX_TOOL_CALLS=12             # cap tool calls per request (0 = off)
LOOP_MAX_TOOL_REPEAT=2             # cap identical name+input calls (0 = off)
LOOP_MAX_TOKENS_PER_REQUEST=20000  # token circuit breaker (0 = off)
# Risky Slack methods to block (dot/underscore-insensitive; trailing * = prefix):
LOOP_BLOCKED_SLACK_METHODS=chat.delete,conversations.archive,conversations.kick,admin.*
# Max bytes for a single Slack file attachment Loop will download + read (0 = no cap).
# Needs the `files:read` bot scope. Images (png/jpeg/gif/webp) go to the model
# natively; text/code/json are inlined; other types are skipped.
LOOP_MAX_FILE_BYTES=8388608

# ── Evaluation (Pillar 01) ────────────────────────────────────
# `loop-eval` runs evals/golden.json through the real agent. Override the set:
# LOOP_EVAL_DATASET=./evals/golden.json
